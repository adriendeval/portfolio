<!DOCTYPE html>
<html lang="fr">
	<head>
		<meta charset="UTF-8" name="viewport" content="width=device-width, initial-scale=1">

		<title>
			{% block title %}Portfolio - Adrien Deval{% endblock %}
		</title>
		<link rel="icon" href="/assets/favicon.ico"/>

		<style>
			{% block stylesheets %}
				@import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300..700&display=swap');
				@import url('https://cdn-uicons.flaticon.com/3.0.0/uicons-regular-rounded/css/uicons-regular-rounded.css');

				* {
					font-family: 'Space Grotesk', sans-serif;
				}

				#nav-toggle:checked ~ #nav-header #nav-icon span {
					transform: rotate(45deg) translate(5px, 5px);
				}

				#nav-toggle:checked ~ #nav-header #nav-icon span:nth-child(2) {
					opacity: 0;
				}

				#nav-toggle:checked ~ #nav-header #nav-icon span:nth-child(3) {
					transform: rotate(-45deg) translate(7px, -6px);
				}

				#nav-toggle:checked ~ #nav-content {
					display: block;
				}

				.fi {
					display: inline-block;
					font-style: normal;
					font-variant: normal;
					text-rendering: auto;
					-webkit-font-smoothing: antialiased;
					vertical-align: middle;
					padding-right: 4px;
				}

				::selection {
					background-color: #4F39F6;
					color: white;
				}
			{% endblock %}
		</style>

		{% block javascripts %}
			{% block importmap %}
				{# {{ importmap('app') }} #}
			{% endblock %}
			<script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
			<script src="https://cdn.jsdelivr.net/npm/@tailwindplus/elements@1" type="module"></script>
		{% endblock %}
	</head>
	<body
		class="bg-slate-50 text-slate-900 flex flex-col min-h-screen font-sans antialiased">
		{# Barre de navigation #}
		<nav class="bg-slate-900/95 backdrop-blur-sm sticky top-0 z-50 border-b border-slate-800 shadow-lg">
			{% set current_route = app.request.attributes.get('_route') %}
			<div
				class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
				{# Checkbox Hack for Mobile Menu (matches CSS in head) #}
				<input type="checkbox" id="nav-toggle" class="peer hidden"/>

				<div
					id="nav-header" class="flex justify-between h-16 items-center relative z-20">
					{# Logo #}
					<a href="{{ path('app_home') }}" class="flex-shrink-0 flex items-center gap-2 text-xl font-bold text-white tracking-tight hover:text-indigo-400 transition-colors">
						Adrien Deval
					</a>

					{# Mobile Menu Button #}
					<label for="nav-toggle" id="nav-icon" class="sm:hidden text-slate-300 hover:text-white cursor-pointer p-2 rounded-md hover:bg-slate-800 transition-colors select-none">
						<div class="w-6 flex flex-col gap-1.5 relative">
							<span class="block w-6 h-0.5 bg-current transform transition-all duration-300 origin-center"></span>
							<span class="block w-6 h-0.5 bg-current transform transition-all duration-300 origin-center"></span>
							<span class="block w-6 h-0.5 bg-current transform transition-all duration-300 origin-center"></span>
						</div>
					</label>

					{# Desktop Menu #}
					<div class="hidden sm:flex sm:items-center sm:space-x-1">
						<a href="{{ path('app_competences') }}" class="{{ current_route == 'app_competences' ? 'bg-slate-800 text-white' : 'text-slate-300 hover:text-white hover:bg-slate-800' }} px-3 py-2 rounded-md text-sm font-medium transition-all duration-200">
							Compétences
						</a>
						<a href="{{ path('app_formations') }}" class="{{ current_route == 'app_formations' ? 'bg-slate-800 text-white' : 'text-slate-300 hover:text-white hover:bg-slate-800' }} px-3 py-2 rounded-md text-sm font-medium transition-all duration-200">
							Formations
						</a>
						<a href="{{ path('app_experiences_professionnelles') }}" class="{{ current_route == 'app_experiences_professionnelles' ? 'bg-slate-800 text-white' : 'text-slate-300 hover:text-white hover:bg-slate-800' }} px-3 py-2 rounded-md text-sm font-medium transition-all duration-200">
							Expériences professionnelles
						</a>
						<a href="{{ path('app_projet_professionnel') }}" class="{{ current_route == 'app_projet_professionnel' ? 'bg-slate-800 text-white' : 'text-slate-300 hover:text-white hover:bg-slate-800' }} px-3 py-2 rounded-md text-sm font-medium transition-all duration-200">
							Projet professionnel
						</a>
						<a href="{{ path('app_certifications') }}" class="{{ current_route == 'app_certifications' ? 'bg-slate-800 text-white' : 'text-slate-300 hover:text-white hover:bg-slate-800' }} px-3 py-2 rounded-md text-sm font-medium transition-all duration-200">
							Certifications
						</a>
						<a href="{{ path('app_veille_informatique') }}" class="{{ current_route == 'app_veille_informatique' ? 'bg-slate-800 text-white' : 'text-slate-300 hover:text-white hover:bg-slate-800' }} px-3 py-2 rounded-md text-sm font-medium transition-all duration-200">
							Veille informatique
						</a>
					</div>
				</div>

				{# Mobile Menu Content - Improved #}
				<div id="nav-content" class="hidden peer-checked:block sm:hidden absolute left-0 right-0 top-16 bg-slate-900 border-b border-slate-800 shadow-2xl z-10 animate-in slide-in-from-top-2 duration-200">
					<div class="flex flex-col p-4 space-y-2">
						<a href="{{ path('app_competences') }}" class="{{ current_route == 'app_competences' ? 'bg-slate-800 text-white border-slate-700' : 'text-slate-300 hover:text-white hover:bg-slate-800 border-transparent hover:border-slate-700' }} block px-4 py-3 rounded-lg text-base font-medium transition-colors border">
							<i class="fi fi-rr-star mr-2 text-indigo-400"></i>
							Compétences
						</a>
						<a href="{{ path('app_formations') }}" class="{{ current_route == 'app_formations' ? 'bg-slate-800 text-white border-slate-700' : 'text-slate-300 hover:text-white hover:bg-slate-800 border-transparent hover:border-slate-700' }} block px-4 py-3 rounded-lg text-base font-medium transition-colors border">
							<i class="fi fi-rr-graduation-cap mr-2 text-indigo-400"></i>
							Formations
						</a>
						<a href="{{ path('app_experiences_professionnelles') }}" class="{{ current_route == 'app_experiences_professionnelles' ? 'bg-slate-800 text-white border-slate-700' : 'text-slate-300 hover:text-white hover:bg-slate-800 border-transparent hover:border-slate-700' }} block px-4 py-3 rounded-lg text-base font-medium transition-colors border">
							<i class="fi fi-rr-briefcase mr-2 text-indigo-400"></i>
							Expériences professionnelles
						</a>
						<a href="{{ path('app_projet_professionnel') }}" class="{{ current_route == 'app_projet_professionnel' ? 'bg-slate-800 text-white border-slate-700' : 'text-slate-300 hover:text-white hover:bg-slate-800 border-transparent hover:border-slate-700' }} block px-4 py-3 rounded-lg text-base font-medium transition-colors border">
							<i class="fi fi-rr-rocket-lunch mr-2 text-indigo-400"></i>
							Projet professionnel
						</a>
						<a href="{{ path('app_certifications') }}" class="{{ current_route == 'app_certifications' ? 'bg-slate-800 text-white border-slate-700' : 'text-slate-300 hover:text-white hover:bg-slate-800 border-transparent hover:border-slate-700' }} block px-4 py-3 rounded-lg text-base font-medium transition-colors border">
							<i class="fi fi-rr-certificate mr-2 text-indigo-400"></i>
							Certifications
						</a>
						<a href="{{ path('app_veille_informatique') }}" class="{{ current_route == 'app_veille_informatique' ? 'bg-slate-800 text-white border-slate-700' : 'text-slate-300 hover:text-white hover:bg-slate-800 border-transparent hover:border-slate-700' }} block px-4 py-3 rounded-lg text-base font-medium transition-colors border">
							<i class="fi fi-rr-search-alt mr-2 text-indigo-400"></i>
							Veille informatique
						</a>
					</div>
				</div>
			</div>
		</nav>

		{# Contenu des pages #}
		<main class="flex-grow w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 sm:py-12"> {% block body %}{% endblock %}
			</main>

			{# Pied de page #}
			<footer class="bg-slate-900 text-slate-400 py-6 border-t border-slate-800 mt-auto">
				<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col sm:flex-row justify-between items-center gap-4 text-center sm:text-left">
					<div class="text-sm">
						&copy;
						{{ "now"|date("Y") }}
						Adrien Deval
						<span class="hidden sm:inline">|</span>
						Tous droits réservés.<br>
						Développé avec
						<a href="https://symfony.com/" target="_blank" rel="noopener noreferrer" class="hover:text-white underline">Symfony</a>.
					</div>
					<div class="flex items-center space-x-6">
						<a href="/mentions-legales" class="hover:text-white underline">Mentions légales</a>
						<a href="https://github.com/adriendeval" class="hover:text-white transition-colors" aria-label="GitHub" target="_blank" rel="noopener noreferrer">
							<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-5 w-5 fill-current" aria-hidden="true" focusable="false">
								<path d="M12 2C6.477 2 2 6.595 2 12.263c0 4.535 2.865 8.383 6.839 9.742c.5.096.682-.223.682-.495c0-.245-.009-.894-.014-1.755c-2.782.617-3.369-1.375-3.369-1.375c-.455-1.19-1.11-1.507-1.11-1.507c-.908-.637.069-.624.069-.624c1.004.072 1.532 1.06 1.532 1.06c.892 1.568 2.341 1.116 2.91.853c.091-.67.35-1.116.636-1.372c-2.22-.26-4.555-1.14-4.555-5.073c0-1.12.39-2.036 1.029-2.754c-.103-.26-.446-1.307.098-2.724c0 0 .84-.277 2.75 1.052A9.335 9.335 0 0 1 12 7.374c.85.004 1.705.117 2.504.344c1.909-1.329 2.748-1.052 2.748-1.052c.546 1.417.203 2.464.1 2.724c.64.718 1.028 1.634 1.028 2.754c0 3.943-2.339 4.809-4.566 5.065c.359.319.678.949.678 1.913c0 1.38-.012 2.493-.012 2.832c0 .275.18.596.688.494C19.138 20.643 22 16.796 22 12.263C22 6.595 17.523 2 12 2z"/>
							</svg>
						</a>
						<a href="https://www.linkedin.com/in/adriendeval35/" class="hover:text-white transition-colors" aria-label="LinkedIn" target="_blank" rel="noopener noreferrer">
							<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-5 w-5 fill-current" aria-hidden="true" focusable="false">
								<path d="M19 3A2 2 0 0 1 21 5V19A2 2 0 0 1 19 21H5A2 2 0 0 1 3 19V5A2 2 0 0 1 5 3H19zM8.339 10.339H5.667V18.333H8.339V10.339zM7.003 5.667C6.146 5.667 5.45 6.362 5.45 7.22c0 .857.696 1.553 1.553 1.553s1.553-.696 1.553-1.553c0-.858-.696-1.553-1.553-1.553zm11.33 7.765c0-2.4-1.28-3.519-2.987-3.519c-1.375 0-1.992.756-2.337 1.288v-1.106h-2.672c.035.733 0 7.905 0 7.905h2.672v-4.414c0-.236.017-.472.086-.641c.188-.472.618-.961 1.339-.961c.945 0 1.324.725 1.324 1.787V18h2.672v-4.568z"/>
							</svg>
						</a>
					</div>
				</div>
			</footer>
		</body>
	</html>
